# ─── DevTrace Studio Environment Configuration ───
# Copy this file to .env and adjust values for your environment.

# Node environment: development | production | test
NODE_ENV=production

# Collector port
PORT=9000

# ─── Security ───
# Set an API key to require authentication on all endpoints (except health).
# Leave empty for open local-dev mode.
DEVTRACE_API_KEY=

# Comma-separated allowed CORS origins. Use * for any origin (dev only).
DEVTRACE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Rate Limiting ───
DEVTRACE_RATE_LIMIT_WINDOW=60
DEVTRACE_RATE_LIMIT_MAX=300
DEVTRACE_INGEST_RATE_MAX=600

# ─── Storage ───
DEVTRACE_MAX_EVENTS=50000
DEVTRACE_SLOW_THRESHOLD_MS=150

# ─── Logging ───
# pino levels: fatal, error, warn, info, debug, trace
DEVTRACE_LOG_LEVEL=info

